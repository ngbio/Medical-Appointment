# App
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-domain.onrender.com,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-render-domain.onrender.com,https://your-domain.com

# Database (Aiven MySQL in production)
DB_ENGINE=django.db.backends.mysql
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=21927
DB_NAME=medical_appointment
DB_USER=avnadmin
DB_PASSWORD=your_db_password
MYSQL_SSL_CA=/etc/secrets/ca.pem
DB_CONN_MAX_AGE=600

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OAuth
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password

# Celery
CELERY_BROKER_URL=amqp://guest:your_rabbitmq_password@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
